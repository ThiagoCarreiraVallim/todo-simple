# Variáveis para o deploy no Dokploy.
# Cole estas no painel do Dokploy → sua aplicação Compose → Environment,
# ajustando os valores. NÃO comite segredos reais.

# --- Domínios (aponte os registros DNS A/AAAA para o IP do servidor Dokploy) ---
WEB_DOMAIN=app.seudominio.com
API_DOMAIN=api.seudominio.com

# --- Postgres (embutido na stack) ---
POSTGRES_USER=todo
POSTGRES_DB=todo
# Gere uma senha forte, ex.: openssl rand -base64 24
POSTGRES_PASSWORD=troque-esta-senha
